  <diagram id="WAOXSMkEMzDqDiNMyj-I" name="Page-8">
    <mxGraphModel dx="2892" dy="1552" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Mission Management - BPMN Level Process\n\n|Employee|\nstart\n:Create Mission Request;\n\n:Fill Mission Details;\nnote right\nOrigin / Destination\nTime / Type / Reason\nPassengers\nend note\n\n:Submit Request;\n\n|System|\n:Store Mission Request;\n:Set Status = Pending Approval;\n\n|Manager|\n:Review Mission Request;\n\nif (Approve?) then (Yes)\n\n  :Approve Request;\n\n  |System|\n  :Update Status = Approved;\n\n  |Dispatcher|\n  :Start Assignment Process;\n\n  :Check Available Drivers;\n  :Check Available Vehicles;\n  :Check Insurance Status;\n\n  if (Valid Resources?) then (Yes)\n\n    :Assign Driver;\n    :Assign Vehicle;\n    :Create Mission Assignment;\n\n    |Driver|\n    :Receive Mission Notification;\n\n    :Start Mission;\n\n    :Record Entry Time;\n    :Record Exit Time;\n\n    :Start Travel;\n\n    :Record Departure KM;\n    :Record Return KM;\n\n    |System|\n    :Calculate Distance;\n    :Calculate Hours;\n\n    if (Type == Urban?) then (Yes)\n        :Calculate Hourly Payment;\n    else (No)\n        :Calculate KM Payment;\n        :Calculate Sleep Hours;\n    endif\n\n    :Generate Mission Execution Record;\n\n    |Finance|\n    :Validate Execution Data;\n    :Calculate Final Cost;\n\n    :Apply Contract Rules;\n    :Compute Driver Payment;\n\n    :Generate Monthly Settlement Entry;\n\n    stop\n\n  else (No)\n    :Reject Assignment;\n    :Return to Dispatcher;\n    stop\n  endif\n\nelse (No)\n  :Reject Request;\n\n  |System|\n  :Set Status = Rejected;\n\n  stop\nendif\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="YA99V7x-u0HqsOXm6kol-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="2029" width="2329" x="20" y="10" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
