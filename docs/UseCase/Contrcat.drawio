        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nleft to right direction\n\nactor Manager\nactor Finance\nactor Admin\n\nrectangle \&quot;Reporting &amp; Analytics\&quot; {\n\n  usecase \&quot;Mission Reports\&quot; as UC1\n  usecase \&quot;Driver Performance Report\&quot; as UC2\n  usecase \&quot;Vehicle Usage Report\&quot; as UC3\n  usecase \&quot;Cost Analysis\&quot; as UC4\n  usecase \&quot;Monthly Payroll Report\&quot; as UC5\n}\n\nManager --&gt; UC1\nManager --&gt; UC2\nManager --&gt; UC3\n\nFinance --&gt; UC4\nFinance --&gt; UC5\n\nAdmin --&gt; UC1\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="2gP9toQParMl4pI7qMSF-1">
