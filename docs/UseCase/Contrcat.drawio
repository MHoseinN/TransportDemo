  <diagram name="Page-1" id="RV214HHKKa2DxlZNLsH3">
    <mxGraphModel dx="937" dy="488" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nleft to right direction\n\nactor Admin\nactor \&quot;IT Operator\&quot; as IT\n\nrectangle \&quot;Base Management System\&quot; {\n\n  usecase \&quot;Manage Provinces\&quot; as UC1\n  usecase \&quot;Manage Cities\&quot; as UC2\n  usecase \&quot;Manage Branches\&quot; as UC3\n  usecase \&quot;Manage Org Units\&quot; as UC4\n  usecase \&quot;Manage Users\&quot; as UC5\n  usecase \&quot;Assign Roles\&quot; as UC6\n}\n\nAdmin --&gt; UC1\nAdmin --&gt; UC2\nAdmin --&gt; UC3\nAdmin --&gt; UC4\nAdmin --&gt; UC5\nAdmin --&gt; UC6\n\nIT --&gt; UC1\nIT --&gt; UC2\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="U73_O9_N6PY8V1DKaJTq-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="425" width="306" x="190" y="160" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="4vmmmzRlTU0BDIN0UiuK" name="Page-2">
    <mxGraphModel dx="1963" dy="580" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nhide circle\nskinparam linetype ortho\n\n&#39; =======================\n&#39; Geographic\n&#39; =======================\nentity Province {\n  *ProvinceId : int\n  --\n  Name : string\n  Code : string\n  IsActive : bool\n}\n\nentity City {\n  *CityId : int\n  --\n  ProvinceId : int\n  Name : string\n  Code : string\n  IsActive : bool\n}\n\nProvince ||--o{ City\n\n&#39; =======================\n&#39; Organization &amp; Users\n&#39; =======================\nentity Branch {\n  *BranchId : int\n  --\n  Name : string\n  Code : string\n}\n\nentity OrganizationUnit {\n  *OrganizationUnitId : int\n  --\n  ParentId : int\n  Name : string\n  Code : string\n}\n\nentity UserAccount {\n  *UserId : int\n  --\n  BranchId : int\n  OrganizationUnitId : int\n  FirstName : string\n  LastName : string\n  NationalCode : string\n  Mobile : string\n}\n\nBranch ||--o{ UserAccount\nOrganizationUnit ||--o{ UserAccount\nOrganizationUnit ||--o{ OrganizationUnit : parent\n\nentity Role {\n  *RoleId : int\n  Name : string\n}\n\nentity UserRole {\n  *UserRoleId : int\n  UserId : int\n  RoleId : int\n}\n\nUserAccount ||--o{ UserRole\nRole ||--o{ UserRole\n\n&#39; =======================\n&#39; Driver &amp; Vehicle\n&#39; =======================\nentity Driver {\n  *DriverId : int\n  --\n  BranchId : int\n  FirstName : string\n  LastName : string\n  NationalCode : string\n  LicenseNo : string\n  InsuranceExpireDate : date\n}\n\nentity Vehicle {\n  *VehicleId : int\n  --\n  Type : string\n  Model : string\n  PlateNo : string\n  ChassisNo : string\n  InsuranceExpireDate : date\n}\n\nBranch ||--o{ Driver\n\n&#39; =======================\n&#39; Contract\n&#39; =======================\nentity Contract {\n  *ContractId : int\n  --\n  DriverId : int\n  VehicleId : int\n  StartDate : date\n  EndDate : date\n  HourlyAmount : decimal\n  KilometerAmount : decimal\n}\n\nDriver ||--o{ Contract\nVehicle ||--o{ Contract\n\n&#39; =======================\n&#39; Mission\n&#39; =======================\nentity MissionRequest {\n  *MissionRequestId : int\n  --\n  RequesterUserId : int\n  OriginCityId : int\n  DestinationCityId : int\n  StartDateTime : datetime\n  EndDateTime : datetime\n  Status : string\n}\n\nUserAccount ||--o{ MissionRequest\nCity ||--o{ MissionRequest\n\nentity MissionApproval {\n  *MissionApprovalId : int\n  --\n  MissionRequestId : int\n  ApproverUserId : int\n  Status : string\n}\n\nMissionRequest ||--o{ MissionApproval\nUserAccount ||--o{ MissionApproval\n\nentity MissionAssignment {\n  *MissionAssignmentId : int\n  --\n  MissionRequestId : int\n  DriverId : int\n  VehicleId : int\n  ContractId : int\n}\n\nMissionRequest ||--o| MissionAssignment\nDriver ||--o{ MissionAssignment\nVehicle ||--o{ MissionAssignment\nContract ||--o{ MissionAssignment\n\n&#39; =======================\n&#39; Execution\n&#39; =======================\nentity MissionExecution {\n  *MissionExecutionId : int\n  --\n  MissionAssignmentId : int\n  DepartureKm : int\n  ReturnKm : int\n  SleepHours : decimal\n  TotalCost : decimal\n}\n\nMissionAssignment ||--o| MissionExecution\n\nentity DriverAttendance {\n  *AttendanceId : int\n  --\n  DriverId : int\n  VehicleId : int\n  EntryTime : datetime\n  ExitTime : datetime\n}\n\nDriver ||--o{ DriverAttendance\nVehicle ||--o{ DriverAttendance\n\n&#39; =======================\n&#39; Costing\n&#39; =======================\nentity MissionCost {\n  *MissionCostId : int\n  --\n  MissionExecutionId : int\n  TotalCost : decimal\n}\n\nMissionExecution ||--o| MissionCost\n\nentity Settlement {\n  *SettlementId : int\n  --\n  DriverId : int\n  Year : int\n  Month : int\n  TotalAmount : decimal\n}\n\nDriver ||--o{ Settlement\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="23Y07f1gR9np3yO9VaMX-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1209.41" width="1349" x="-210" y="22" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
