<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_mission-request" targetNamespace="https://example.com/transport-bpmn">
  <process id="mission-request" name="فرآیند درخواست مأموریت" isExecutable="false">
    <laneSet id="LaneSet_mission-request">
      <lane id="Lane_mission-request_1" name="درخواست‌دهنده">
        <flowNodeRef>Start_MR</flowNodeRef>
        <flowNodeRef>Task_MR_Form</flowNodeRef>
        <flowNodeRef>Task_MR_TripType</flowNodeRef>
        <flowNodeRef>Task_MR_MissionType</flowNodeRef>
        <flowNodeRef>Task_MR_Time</flowNodeRef>
        <flowNodeRef>Task_MR_Route</flowNodeRef>
        <flowNodeRef>Task_MR_Reason</flowNodeRef>
        <flowNodeRef>Gw_MR_WithCompanions</flowNodeRef>
        <flowNodeRef>Task_MR_Companions</flowNodeRef>
        <flowNodeRef>Task_MR_Submit</flowNodeRef>
      </lane>
      <lane id="Lane_mission-request_2" name="مدیر / سطوح تأیید">
        <flowNodeRef>Task_MR_Review</flowNodeRef>
        <flowNodeRef>Gw_MR_Approved</flowNodeRef>
        <flowNodeRef>Gw_MR_MoreLevels</flowNodeRef>
        <flowNodeRef>End_MR_Rejected</flowNodeRef>
      </lane>
      <lane id="Lane_mission-request_3" name="واحد ترابری">
        <flowNodeRef>Task_MR_TransportInbox</flowNodeRef>
        <flowNodeRef>End_MR</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_MR" name="شروع"/>
    <userTask id="Task_MR_Form" name="ورود به فرم درخواست مأموریت"/>
    <task id="Task_MR_TripType" name="انتخاب نوع رفت و برگشت"/>
    <task id="Task_MR_MissionType" name="انتخاب نوع مأموریت"/>
    <task id="Task_MR_Time" name="ثبت زمان شروع و پایان"/>
    <task id="Task_MR_Route" name="ثبت مبدا و مقصد"/>
    <task id="Task_MR_Reason" name="ثبت علت مأموریت و توضیحات"/>
    <exclusiveGateway id="Gw_MR_WithCompanions" name="همراه دارد؟"/>
    <task id="Task_MR_Companions" name="انتخاب سایر مأمورین"/>
    <task id="Task_MR_Submit" name="ثبت درخواست"/>
    <userTask id="Task_MR_Review" name="بررسی درخواست"/>
    <exclusiveGateway id="Gw_MR_Approved" name="تأیید شد؟"/>
    <exclusiveGateway id="Gw_MR_MoreLevels" name="سطح تأیید دیگری باقی مانده؟"/>
    <endEvent id="End_MR_Rejected" name="رد و خاتمه"/>
    <task id="Task_MR_TransportInbox" name="دریافت در کارتابل ترابری"/>
    <endEvent id="End_MR" name="پایان"/>
    <sequenceFlow id="Flow_MR1" sourceRef="Start_MR" targetRef="Task_MR_Form"/>
    <sequenceFlow id="Flow_MR2" sourceRef="Task_MR_Form" targetRef="Task_MR_TripType"/>
    <sequenceFlow id="Flow_MR3" sourceRef="Task_MR_TripType" targetRef="Task_MR_MissionType"/>
    <sequenceFlow id="Flow_MR4" sourceRef="Task_MR_MissionType" targetRef="Task_MR_Time"/>
    <sequenceFlow id="Flow_MR5" sourceRef="Task_MR_Time" targetRef="Task_MR_Route"/>
    <sequenceFlow id="Flow_MR6" sourceRef="Task_MR_Route" targetRef="Task_MR_Reason"/>
    <sequenceFlow id="Flow_MR7" sourceRef="Task_MR_Reason" targetRef="Gw_MR_WithCompanions"/>
    <sequenceFlow id="Flow_MR8" sourceRef="Gw_MR_WithCompanions" targetRef="Task_MR_Companions" name="بله"/>
    <sequenceFlow id="Flow_MR9" sourceRef="Task_MR_Companions" targetRef="Task_MR_Submit"/>
    <sequenceFlow id="Flow_MR10" sourceRef="Gw_MR_WithCompanions" targetRef="Task_MR_Submit" name="خیر"/>
    <sequenceFlow id="Flow_MR11" sourceRef="Task_MR_Submit" targetRef="Task_MR_Review"/>
    <sequenceFlow id="Flow_MR12" sourceRef="Task_MR_Review" targetRef="Gw_MR_Approved"/>
    <sequenceFlow id="Flow_MR13" sourceRef="Gw_MR_Approved" targetRef="End_MR_Rejected" name="خیر"/>
    <sequenceFlow id="Flow_MR14" sourceRef="Gw_MR_Approved" targetRef="Gw_MR_MoreLevels" name="بله"/>
    <sequenceFlow id="Flow_MR15" sourceRef="Gw_MR_MoreLevels" targetRef="Task_MR_Review" name="بله"/>
    <sequenceFlow id="Flow_MR16" sourceRef="Gw_MR_MoreLevels" targetRef="Task_MR_TransportInbox" name="خیر"/>
    <sequenceFlow id="Flow_MR17" sourceRef="Task_MR_TransportInbox" targetRef="End_MR"/>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_mission-request">
    <bpmndi:BPMNPlane id="BPMNPlane_mission-request" bpmnElement="mission-request">
      <bpmndi:BPMNShape id="Lane_mission-request_1_di" bpmnElement="Lane_mission-request_1" isHorizontal="true">
