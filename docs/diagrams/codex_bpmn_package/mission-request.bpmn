      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_MR_MoreLevels_di" bpmnElement="Gw_MR_MoreLevels">
        <dc:Bounds x="2580" y="335" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_MR_Rejected_di" bpmnElement="End_MR_Rejected">
        <dc:Bounds x="2790" y="342" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_MR_TransportInbox_di" bpmnElement="Task_MR_TransportInbox">
        <dc:Bounds x="2790" y="540" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_MR_di" bpmnElement="End_MR">
        <dc:Bounds x="3000" y="562" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_MR1_di" bpmnElement="Flow_MR1">
