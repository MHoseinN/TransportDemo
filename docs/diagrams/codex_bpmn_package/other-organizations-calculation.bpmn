<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_other-organizations-calculation" targetNamespace="https://example.com/transport-bpmn">
  <process id="other-organizations-calculation" name="فرآیند محاسبات سایر سازمان‌ها" isExecutable="false">
    <laneSet id="LaneSet_other-organizations-calculation">
      <lane id="Lane_other-organizations-calculation_1" name="کارشناس ترابری / ثبت‌کننده">
        <flowNodeRef>Start_OC</flowNodeRef>
        <flowNodeRef>Task_OC_SelectOrg</flowNodeRef>
        <flowNodeRef>Gw_OC_Type</flowNodeRef>
        <flowNodeRef>Task_OC_Hours</flowNodeRef>
        <flowNodeRef>Task_OC_CityKm</flowNodeRef>
        <flowNodeRef>Task_OC_OutKm</flowNodeRef>
      </lane>
      <lane id="Lane_other-organizations-calculation_2" name="مالی">
        <flowNodeRef>Task_OC_HourCalc</flowNodeRef>
        <flowNodeRef>Task_OC_CityCalc</flowNodeRef>
        <flowNodeRef>Task_OC_OutBase</flowNodeRef>
        <flowNodeRef>Task_OC_Driving</flowNodeRef>
        <flowNodeRef>Task_OC_Sleep</flowNodeRef>
        <flowNodeRef>Task_OC_SleepAmount</flowNodeRef>
        <flowNodeRef>Task_OC_Extras</flowNodeRef>
        <flowNodeRef>Task_OC_Payable</flowNodeRef>
        <flowNodeRef>Task_OC_Register</flowNodeRef>
        <flowNodeRef>End_OC</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_OC" name="شروع"/>
    <userTask id="Task_OC_SelectOrg" name="انتخاب سازمان / مدل محاسبه"/>
    <exclusiveGateway id="Gw_OC_Type" name="نوع محاسبه"/>
    <task id="Task_OC_Hours" name="خواندن ساعات ورود و خروج"/>
    <task id="Task_OC_CityKm" name="خواندن کیلومتر مأموریت درون‌شهری"/>
    <task id="Task_OC_OutKm" name="خواندن کیلومتر رفت و برگشت برون‌شهری"/>
    <task id="Task_OC_HourCalc" name="ضرب در مبلغ ساعتی قرارداد"/>
    <task id="Task_OC_CityCalc" name="ضرب در نرخ کیلومتری"/>
    <task id="Task_OC_OutBase" name="محاسبه مبلغ کیلومتری"/>
    <task id="Task_OC_Driving" name="محاسبه ساعات رانندگی"/>
    <task id="Task_OC_Sleep" name="محاسبه ساعات خواب"/>
    <task id="Task_OC_SleepAmount" name="ضرب خواب در نرخ خواب"/>
    <task id="Task_OC_Extras" name="اعمال توقفی / جریمه / اضافات"/>
    <task id="Task_OC_Payable" name="تولید مبلغ قابل پرداخت"/>
    <task id="Task_OC_Register" name="ثبت در کارکرد و حقوق راننده"/>
    <endEvent id="End_OC" name="پایان"/>
    <sequenceFlow id="Flow_OC1" sourceRef="Start_OC" targetRef="Task_OC_SelectOrg"/>
    <sequenceFlow id="Flow_OC2" sourceRef="Task_OC_SelectOrg" targetRef="Gw_OC_Type"/>
    <sequenceFlow id="Flow_OC3" sourceRef="Gw_OC_Type" targetRef="Task_OC_Hours" name="درون‌شهری ساعتی"/>
    <sequenceFlow id="Flow_OC4" sourceRef="Task_OC_Hours" targetRef="Task_OC_HourCalc"/>
    <sequenceFlow id="Flow_OC5" sourceRef="Task_OC_HourCalc" targetRef="Task_OC_Payable"/>
    <sequenceFlow id="Flow_OC6" sourceRef="Gw_OC_Type" targetRef="Task_OC_CityKm" name="درون‌شهری کیلومتری"/>
    <sequenceFlow id="Flow_OC7" sourceRef="Task_OC_CityKm" targetRef="Task_OC_CityCalc"/>
    <sequenceFlow id="Flow_OC8" sourceRef="Task_OC_CityCalc" targetRef="Task_OC_Payable"/>
    <sequenceFlow id="Flow_OC9" sourceRef="Gw_OC_Type" targetRef="Task_OC_OutKm" name="برون‌شهری"/>
    <sequenceFlow id="Flow_OC10" sourceRef="Task_OC_OutKm" targetRef="Task_OC_OutBase"/>
    <sequenceFlow id="Flow_OC11" sourceRef="Task_OC_OutBase" targetRef="Task_OC_Driving"/>
    <sequenceFlow id="Flow_OC12" sourceRef="Task_OC_Driving" targetRef="Task_OC_Sleep"/>
    <sequenceFlow id="Flow_OC13" sourceRef="Task_OC_Sleep" targetRef="Task_OC_SleepAmount"/>
    <sequenceFlow id="Flow_OC14" sourceRef="Task_OC_SleepAmount" targetRef="Task_OC_Extras"/>
    <sequenceFlow id="Flow_OC15" sourceRef="Task_OC_Extras" targetRef="Task_OC_Payable"/>
    <sequenceFlow id="Flow_OC16" sourceRef="Task_OC_Payable" targetRef="Task_OC_Register"/>
    <sequenceFlow id="Flow_OC17" sourceRef="Task_OC_Register" targetRef="End_OC"/>
  </process>
