<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_mission-info-and-kilometer" targetNamespace="https://example.com/transport-bpmn">
  <process id="mission-info-and-kilometer" name="فرآیند ثبت اطلاعات و کیلومتر مأموریت" isExecutable="false">
    <laneSet id="LaneSet_mission-info-and-kilometer">
      <lane id="Lane_mission-info-and-kilometer_1" name="راننده">
        <flowNodeRef>Start_MI</flowNodeRef>
        <flowNodeRef>Task_MI_TimeData</flowNodeRef>
        <flowNodeRef>Task_MI_KmData</flowNodeRef>
      </lane>
      <lane id="Lane_mission-info-and-kilometer_2" name="کاربر / مسئول ثبت">
        <flowNodeRef>Task_MI_Form</flowNodeRef>
        <flowNodeRef>Task_MI_Select</flowNodeRef>
        <flowNodeRef>Task_MI_Depart</flowNodeRef>
        <flowNodeRef>Task_MI_Return</flowNodeRef>
        <flowNodeRef>Task_MI_Km</flowNodeRef>
        <flowNodeRef>Task_MI_Distance</flowNodeRef>
        <flowNodeRef>Task_MI_Costs</flowNodeRef>
        <flowNodeRef>Gw_MI_Complete</flowNodeRef>
        <flowNodeRef>Task_MI_Error</flowNodeRef>
      </lane>
      <lane id="Lane_mission-info-and-kilometer_3" name="مالی">
        <flowNodeRef>Task_MI_Calc</flowNodeRef>
        <flowNodeRef>Gw_MI_Recalc</flowNodeRef>
        <flowNodeRef>Task_MI_Save</flowNodeRef>
        <flowNodeRef>Task_MI_Report</flowNodeRef>
        <flowNodeRef>End_MI</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_MI" name="شروع"/>
    <task id="Task_MI_TimeData" name="ارائه زمان رفت و برگشت"/>
    <task id="Task_MI_KmData" name="ارائه کیلومتر رفت و برگشت"/>
    <userTask id="Task_MI_Form" name="ورود به فرم ثبت اطلاعات مأموریت"/>
    <task id="Task_MI_Select" name="انتخاب مأموریت تخصیص‌یافته"/>
    <task id="Task_MI_Depart" name="ثبت تاریخ و ساعت رفت"/>
    <task id="Task_MI_Return" name="ثبت تاریخ و ساعت برگشت"/>
    <task id="Task_MI_Km" name="ثبت کیلومتر رفت و برگشت"/>
    <task id="Task_MI_Distance" name="محاسبه مسافت"/>
    <task id="Task_MI_Costs" name="ورود هزینه‌های مأموریت"/>
    <exclusiveGateway id="Gw_MI_Complete" name="اطلاعات کامل و معتبر است؟"/>
    <task id="Task_MI_Error" name="نمایش خطا و اصلاح"/>
    <task id="Task_MI_Calc" name="محاسبه حقوق مأموریت"/>
    <exclusiveGateway id="Gw_MI_Recalc" name="نیاز به محاسبه مجدد دارد؟"/>
    <task id="Task_MI_Save" name="ثبت نهایی اطلاعات مأموریت"/>
    <task id="Task_MI_Report" name="گزارش مالی و عملیاتی"/>
    <endEvent id="End_MI" name="پایان"/>
    <sequenceFlow id="Flow_MI1" sourceRef="Start_MI" targetRef="Task_MI_TimeData"/>
    <sequenceFlow id="Flow_MI2" sourceRef="Task_MI_TimeData" targetRef="Task_MI_KmData"/>
    <sequenceFlow id="Flow_MI3" sourceRef="Task_MI_KmData" targetRef="Task_MI_Form"/>
    <sequenceFlow id="Flow_MI4" sourceRef="Task_MI_Form" targetRef="Task_MI_Select"/>
    <sequenceFlow id="Flow_MI5" sourceRef="Task_MI_Select" targetRef="Task_MI_Depart"/>
    <sequenceFlow id="Flow_MI6" sourceRef="Task_MI_Depart" targetRef="Task_MI_Return"/>
    <sequenceFlow id="Flow_MI7" sourceRef="Task_MI_Return" targetRef="Task_MI_Km"/>
    <sequenceFlow id="Flow_MI8" sourceRef="Task_MI_Km" targetRef="Task_MI_Distance"/>
    <sequenceFlow id="Flow_MI9" sourceRef="Task_MI_Distance" targetRef="Task_MI_Costs"/>
    <sequenceFlow id="Flow_MI10" sourceRef="Task_MI_Costs" targetRef="Gw_MI_Complete"/>
    <sequenceFlow id="Flow_MI11" sourceRef="Gw_MI_Complete" targetRef="Task_MI_Error" name="خیر"/>
    <sequenceFlow id="Flow_MI12" sourceRef="Task_MI_Error" targetRef="Task_MI_Depart"/>
    <sequenceFlow id="Flow_MI13" sourceRef="Gw_MI_Complete" targetRef="Task_MI_Calc" name="بله"/>
    <sequenceFlow id="Flow_MI14" sourceRef="Task_MI_Calc" targetRef="Gw_MI_Recalc"/>
    <sequenceFlow id="Flow_MI15" sourceRef="Gw_MI_Recalc" targetRef="Task_MI_Costs" name="بله"/>
    <sequenceFlow id="Flow_MI16" sourceRef="Gw_MI_Recalc" targetRef="Task_MI_Save" name="خیر"/>
    <sequenceFlow id="Flow_MI17" sourceRef="Task_MI_Save" targetRef="Task_MI_Report"/>
    <sequenceFlow id="Flow_MI18" sourceRef="Task_MI_Report" targetRef="End_MI"/>
  </process>
