<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_transport-main-process" targetNamespace="https://example.com/transport-bpmn">
  <process id="transport-main-process" name="فرآیند اصلی سامانه ترابری" isExecutable="false">
    <laneSet id="LaneSet_transport-main-process">
      <lane id="Lane_transport-main-process_1" name="درخواست‌دهنده">
        <flowNodeRef>Start_Main</flowNodeRef>
        <flowNodeRef>Task_Request</flowNodeRef>
      </lane>
      <lane id="Lane_transport-main-process_2" name="مدیران / سطوح تأیید">
        <flowNodeRef>Task_Approve</flowNodeRef>
        <flowNodeRef>Gw_Approved</flowNodeRef>
        <flowNodeRef>End_Rejected</flowNodeRef>
      </lane>
      <lane id="Lane_transport-main-process_3" name="کارشناس ترابری">
        <flowNodeRef>Gw_Pre</flowNodeRef>
        <flowNodeRef>Task_Branches</flowNodeRef>
        <flowNodeRef>Task_CityProvince</flowNodeRef>
        <flowNodeRef>Task_Vehicle</flowNodeRef>
        <flowNodeRef>Task_Driver</flowNodeRef>
        <flowNodeRef>Task_Contract</flowNodeRef>
        <flowNodeRef>Task_Inbox</flowNodeRef>
        <flowNodeRef>Task_SelectDriver</flowNodeRef>
        <flowNodeRef>Task_AssignVehicle</flowNodeRef>
        <flowNodeRef>Gw_Valid</flowNodeRef>
        <flowNodeRef>Task_Mission</flowNodeRef>
        <flowNodeRef>Gw_MissionType</flowNodeRef>
        <flowNodeRef>Task_EntryExit</flowNodeRef>
        <flowNodeRef>Task_MissionInfo</flowNodeRef>
      </lane>
      <lane id="Lane_transport-main-process_4" name="مالی">
        <flowNodeRef>Task_Calc</flowNodeRef>
        <flowNodeRef>Gw_SpecialCalc</flowNodeRef>
        <flowNodeRef>Task_OtherOrgs</flowNodeRef>
        <flowNodeRef>Task_Finalize</flowNodeRef>
        <flowNodeRef>End_Main</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_Main" name="شروع"/>
    <exclusiveGateway id="Gw_Pre" name="پیش‌نیازها آماده است؟"/>
    <task id="Task_Branches" name="ثبت شعب"/>
    <task id="Task_CityProvince" name="ثبت شهر و استان"/>
    <task id="Task_Vehicle" name="ثبت خودرو"/>
    <task id="Task_Driver" name="ثبت راننده"/>
    <task id="Task_Contract" name="ثبت قرارداد"/>
    <userTask id="Task_Request" name="ثبت درخواست مأموریت"/>
    <userTask id="Task_Approve" name="بررسی درخواست"/>
    <exclusiveGateway id="Gw_Approved" name="تأیید شد؟"/>
    <endEvent id="End_Rejected" name="رد و خاتمه"/>
    <task id="Task_Inbox" name="دریافت در کارتابل ترابری"/>
    <userTask id="Task_SelectDriver" name="انتخاب راننده"/>
    <userTask id="Task_AssignVehicle" name="انتصاب خودرو"/>
    <exclusiveGateway id="Gw_Valid" name="راننده/خودرو معتبر و در دسترس هستند؟"/>
    <task id="Task_Mission" name="اعزام و انجام مأموریت"/>
    <exclusiveGateway id="Gw_MissionType" name="نوع مأموریت چیست؟"/>
    <task id="Task_EntryExit" name="ثبت ورود و خروج راننده"/>
    <task id="Task_MissionInfo" name="ثبت اطلاعات و کیلومتر مأموریت"/>
    <task id="Task_Calc" name="محاسبه حقوق و هزینه"/>
    <exclusiveGateway id="Gw_SpecialCalc" name="مدل محاسبه خاص فعال است؟"/>
    <task id="Task_OtherOrgs" name="اعمال محاسبات سایر سازمان‌ها"/>
    <task id="Task_Finalize" name="ثبت نهایی و گزارش‌گیری"/>
    <endEvent id="End_Main" name="پایان"/>
    <sequenceFlow id="Flow_1" sourceRef="Start_Main" targetRef="Gw_Pre"/>
    <sequenceFlow id="Flow_2" sourceRef="Gw_Pre" targetRef="Task_Branches" name="خیر"/>
    <sequenceFlow id="Flow_3" sourceRef="Task_Branches" targetRef="Task_CityProvince"/>
    <sequenceFlow id="Flow_4" sourceRef="Task_CityProvince" targetRef="Task_Vehicle"/>
    <sequenceFlow id="Flow_5" sourceRef="Task_Vehicle" targetRef="Task_Driver"/>
    <sequenceFlow id="Flow_6" sourceRef="Task_Driver" targetRef="Task_Contract"/>
    <sequenceFlow id="Flow_7" sourceRef="Task_Contract" targetRef="Task_Request"/>
    <sequenceFlow id="Flow_8" sourceRef="Gw_Pre" targetRef="Task_Request" name="بله"/>
    <sequenceFlow id="Flow_9" sourceRef="Task_Request" targetRef="Task_Approve"/>
    <sequenceFlow id="Flow_10" sourceRef="Task_Approve" targetRef="Gw_Approved"/>
    <sequenceFlow id="Flow_11" sourceRef="Gw_Approved" targetRef="End_Rejected" name="خیر"/>
    <sequenceFlow id="Flow_12" sourceRef="Gw_Approved" targetRef="Task_Inbox" name="بله"/>
    <sequenceFlow id="Flow_13" sourceRef="Task_Inbox" targetRef="Task_SelectDriver"/>
    <sequenceFlow id="Flow_14" sourceRef="Task_SelectDriver" targetRef="Task_AssignVehicle"/>
    <sequenceFlow id="Flow_15" sourceRef="Task_AssignVehicle" targetRef="Gw_Valid"/>
    <sequenceFlow id="Flow_16" sourceRef="Gw_Valid" targetRef="Task_SelectDriver" name="خیر"/>
    <sequenceFlow id="Flow_17" sourceRef="Gw_Valid" targetRef="Task_Mission" name="بله"/>
    <sequenceFlow id="Flow_18" sourceRef="Task_Mission" targetRef="Gw_MissionType"/>
    <sequenceFlow id="Flow_19" sourceRef="Gw_MissionType" targetRef="Task_EntryExit" name="درون‌شهری ساعتی"/>
    <sequenceFlow id="Flow_20" sourceRef="Task_EntryExit" targetRef="Task_MissionInfo"/>
    <sequenceFlow id="Flow_21" sourceRef="Gw_MissionType" targetRef="Task_MissionInfo" name="سایر"/>
    <sequenceFlow id="Flow_22" sourceRef="Task_MissionInfo" targetRef="Task_Calc"/>
    <sequenceFlow id="Flow_23" sourceRef="Task_Calc" targetRef="Gw_SpecialCalc"/>
    <sequenceFlow id="Flow_24" sourceRef="Gw_SpecialCalc" targetRef="Task_OtherOrgs" name="بله"/>
    <sequenceFlow id="Flow_25" sourceRef="Gw_SpecialCalc" targetRef="Task_Finalize" name="خیر"/>
    <sequenceFlow id="Flow_26" sourceRef="Task_OtherOrgs" targetRef="Task_Finalize"/>
    <sequenceFlow id="Flow_27" sourceRef="Task_Finalize" targetRef="End_Main"/>
  </process>
