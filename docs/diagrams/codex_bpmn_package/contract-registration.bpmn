<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_contract-registration" targetNamespace="https://example.com/transport-bpmn">
  <process id="contract-registration" name="فرآیند ثبت قرارداد" isExecutable="false">
    <laneSet id="LaneSet_contract-registration">
      <lane id="Lane_contract-registration_1" name="کاربر / مسئول اداری">
        <flowNodeRef>Start_C</flowNodeRef>
        <flowNodeRef>Task_C_Form</flowNodeRef>
        <flowNodeRef>Task_C_Party</flowNodeRef>
        <flowNodeRef>Task_C_Vehicle</flowNodeRef>
        <flowNodeRef>Task_C_Dates</flowNodeRef>
        <flowNodeRef>Task_C_Amounts</flowNodeRef>
        <flowNodeRef>Task_C_Insurance</flowNodeRef>
      </lane>
      <lane id="Lane_contract-registration_2" name="پشتیبانی">
        <flowNodeRef>Gw_C_Valid</flowNodeRef>
        <flowNodeRef>Task_C_Error</flowNodeRef>
        <flowNodeRef>Task_C_Save</flowNodeRef>
      </lane>
      <lane id="Lane_contract-registration_3" name="مالی / بیمه">
        <flowNodeRef>Task_C_Use</flowNodeRef>
        <flowNodeRef>End_C</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_C" name="شروع"/>
    <userTask id="Task_C_Form" name="ورود به فرم ثبت قرارداد"/>
    <task id="Task_C_Party" name="انتخاب راننده / طرف قرارداد"/>
    <task id="Task_C_Vehicle" name="انتخاب خودرو"/>
    <task id="Task_C_Dates" name="ثبت تاریخ شروع و پایان"/>
    <task id="Task_C_Amounts" name="ثبت مبلغ ساعتی، رفت، برگشت، خواب"/>
    <task id="Task_C_Insurance" name="ثبت وضعیت بیمه قرارداد"/>
    <exclusiveGateway id="Gw_C_Valid" name="اطلاعات کامل و معتبر است؟"/>
    <task id="Task_C_Error" name="نمایش خطا و اصلاح"/>
    <task id="Task_C_Save" name="ثبت قرارداد"/>
    <task id="Task_C_Use" name="استفاده از قرارداد در محاسبات"/>
    <endEvent id="End_C" name="پایان"/>
    <sequenceFlow id="Flow_C1" sourceRef="Start_C" targetRef="Task_C_Form"/>
    <sequenceFlow id="Flow_C2" sourceRef="Task_C_Form" targetRef="Task_C_Party"/>
    <sequenceFlow id="Flow_C3" sourceRef="Task_C_Party" targetRef="Task_C_Vehicle"/>
    <sequenceFlow id="Flow_C4" sourceRef="Task_C_Vehicle" targetRef="Task_C_Dates"/>
    <sequenceFlow id="Flow_C5" sourceRef="Task_C_Dates" targetRef="Task_C_Amounts"/>
    <sequenceFlow id="Flow_C6" sourceRef="Task_C_Amounts" targetRef="Task_C_Insurance"/>
    <sequenceFlow id="Flow_C7" sourceRef="Task_C_Insurance" targetRef="Gw_C_Valid"/>
    <sequenceFlow id="Flow_C8" sourceRef="Gw_C_Valid" targetRef="Task_C_Error" name="خیر"/>
    <sequenceFlow id="Flow_C9" sourceRef="Task_C_Error" targetRef="Task_C_Party"/>
    <sequenceFlow id="Flow_C10" sourceRef="Gw_C_Valid" targetRef="Task_C_Save" name="بله"/>
    <sequenceFlow id="Flow_C11" sourceRef="Task_C_Save" targetRef="Task_C_Use"/>
    <sequenceFlow id="Flow_C12" sourceRef="Task_C_Use" targetRef="End_C"/>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_contract-registration">
    <bpmndi:BPMNPlane id="BPMNPlane_contract-registration" bpmnElement="contract-registration">
      <bpmndi:BPMNShape id="Lane_contract-registration_1_di" bpmnElement="Lane_contract-registration_1" isHorizontal="true">
        <dc:Bounds x="0" y="0" width="5460" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_contract-registration_2_di" bpmnElement="Lane_contract-registration_2" isHorizontal="true">
        <dc:Bounds x="0" y="220" width="5460" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_contract-registration_3_di" bpmnElement="Lane_contract-registration_3" isHorizontal="true">
        <dc:Bounds x="0" y="440" width="5460" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_C_di" bpmnElement="Start_C">
        <dc:Bounds x="60" y="122" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_C_Form_di" bpmnElement="Task_C_Form">
        <dc:Bounds x="270" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_C_Party_di" bpmnElement="Task_C_Party">
        <dc:Bounds x="480" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_C_Vehicle_di" bpmnElement="Task_C_Vehicle">
        <dc:Bounds x="690" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_C_Dates_di" bpmnElement="Task_C_Dates">
        <dc:Bounds x="900" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_C_Amounts_di" bpmnElement="Task_C_Amounts">
        <dc:Bounds x="1110" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_C_Insurance_di" bpmnElement="Task_C_Insurance">
        <dc:Bounds x="1320" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_C_Valid_di" bpmnElement="Gw_C_Valid">
        <dc:Bounds x="1530" y="335" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_C_Error_di" bpmnElement="Task_C_Error">
        <dc:Bounds x="1740" y="320" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_C_Save_di" bpmnElement="Task_C_Save">
        <dc:Bounds x="1950" y="320" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_C_Use_di" bpmnElement="Task_C_Use">
        <dc:Bounds x="2160" y="540" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_C_di" bpmnElement="End_C">
        <dc:Bounds x="2370" y="562" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_C1_di" bpmnElement="Flow_C1">
        <di:waypoint x="96" y="140.0"/>
        <di:waypoint x="270" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C2_di" bpmnElement="Flow_C2">
        <di:waypoint x="410" y="140.0"/>
        <di:waypoint x="480" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C3_di" bpmnElement="Flow_C3">
        <di:waypoint x="620" y="140.0"/>
        <di:waypoint x="690" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C4_di" bpmnElement="Flow_C4">
        <di:waypoint x="830" y="140.0"/>
        <di:waypoint x="900" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C5_di" bpmnElement="Flow_C5">
        <di:waypoint x="1040" y="140.0"/>
        <di:waypoint x="1110" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C6_di" bpmnElement="Flow_C6">
        <di:waypoint x="1250" y="140.0"/>
        <di:waypoint x="1320" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C7_di" bpmnElement="Flow_C7">
        <di:waypoint x="1460" y="140.0"/>
        <di:waypoint x="1500" y="140.0"/>
        <di:waypoint x="1500" y="360.0"/>
        <di:waypoint x="1530" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C8_di" bpmnElement="Flow_C8">
        <di:waypoint x="1580" y="360.0"/>
        <di:waypoint x="1740" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C9_di" bpmnElement="Flow_C9">
        <di:waypoint x="1880" y="360.0"/>
        <di:waypoint x="1900" y="360.0"/>
        <di:waypoint x="1900" y="60"/>
        <di:waypoint x="460" y="60"/>
        <di:waypoint x="460" y="140.0"/>
        <di:waypoint x="480" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C10_di" bpmnElement="Flow_C10">
        <di:waypoint x="1580" y="360.0"/>
        <di:waypoint x="1950" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C11_di" bpmnElement="Flow_C11">
        <di:waypoint x="2090" y="360.0"/>
        <di:waypoint x="2130" y="360.0"/>
        <di:waypoint x="2130" y="580.0"/>
        <di:waypoint x="2160" y="580.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C12_di" bpmnElement="Flow_C12">
        <di:waypoint x="2300" y="580.0"/>
        <di:waypoint x="2370" y="580.0"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
