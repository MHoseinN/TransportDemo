<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_vehicle-registration" targetNamespace="https://example.com/transport-bpmn">
  <process id="vehicle-registration" name="فرآیند ثبت خودرو" isExecutable="false">
    <laneSet id="LaneSet_vehicle-registration">
      <lane id="Lane_vehicle-registration_1" name="کاربر / مسئول اداری">
        <flowNodeRef>Start_V</flowNodeRef>
        <flowNodeRef>Task_V_Form</flowNodeRef>
        <flowNodeRef>Task_V_Type</flowNodeRef>
        <flowNodeRef>Task_V_Base</flowNodeRef>
        <flowNodeRef>Task_V_Insurance</flowNodeRef>
      </lane>
      <lane id="Lane_vehicle-registration_2" name="پشتیبانی / کنترل">
        <flowNodeRef>Gw_V_Complete</flowNodeRef>
        <flowNodeRef>Task_V_Error</flowNodeRef>
        <flowNodeRef>Gw_V_InsuranceValid</flowNodeRef>
        <flowNodeRef>Task_V_Warn</flowNodeRef>
        <flowNodeRef>Gw_V_Continue</flowNodeRef>
        <flowNodeRef>Task_V_Save</flowNodeRef>
        <flowNodeRef>Task_V_Record</flowNodeRef>
        <flowNodeRef>End_V</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_V" name="شروع"/>
    <userTask id="Task_V_Form" name="ورود به فرم ثبت خودرو"/>
    <task id="Task_V_Type" name="انتخاب نوع خودرو و وضعیت"/>
    <task id="Task_V_Base" name="ورود شماره شاسی، پلاک، مدل و رنگ"/>
    <task id="Task_V_Insurance" name="ورود تاریخ بیمه شخص ثالث و بدنه"/>
    <exclusiveGateway id="Gw_V_Complete" name="اطلاعات اصلی کامل است؟"/>
    <task id="Task_V_Error" name="نمایش خطا و اصلاح"/>
    <exclusiveGateway id="Gw_V_InsuranceValid" name="بیمه معتبر است؟"/>
    <task id="Task_V_Warn" name="نمایش هشدار بیمه"/>
    <exclusiveGateway id="Gw_V_Continue" name="ادامه ثبت مجاز است؟"/>
    <task id="Task_V_Save" name="ثبت خودرو"/>
    <task id="Task_V_Record" name="ایجاد رکورد جستجوپذیر"/>
    <endEvent id="End_V" name="پایان"/>
    <sequenceFlow id="Flow_V1" sourceRef="Start_V" targetRef="Task_V_Form"/>
    <sequenceFlow id="Flow_V2" sourceRef="Task_V_Form" targetRef="Task_V_Type"/>
    <sequenceFlow id="Flow_V3" sourceRef="Task_V_Type" targetRef="Task_V_Base"/>
    <sequenceFlow id="Flow_V4" sourceRef="Task_V_Base" targetRef="Task_V_Insurance"/>
    <sequenceFlow id="Flow_V5" sourceRef="Task_V_Insurance" targetRef="Gw_V_Complete"/>
    <sequenceFlow id="Flow_V6" sourceRef="Gw_V_Complete" targetRef="Task_V_Error" name="خیر"/>
    <sequenceFlow id="Flow_V7" sourceRef="Task_V_Error" targetRef="Task_V_Type"/>
    <sequenceFlow id="Flow_V8" sourceRef="Gw_V_Complete" targetRef="Gw_V_InsuranceValid" name="بله"/>
    <sequenceFlow id="Flow_V9" sourceRef="Gw_V_InsuranceValid" targetRef="Task_V_Warn" name="خیر"/>
    <sequenceFlow id="Flow_V10" sourceRef="Task_V_Warn" targetRef="Gw_V_Continue"/>
    <sequenceFlow id="Flow_V11" sourceRef="Gw_V_Continue" targetRef="Task_V_Type" name="خیر"/>
    <sequenceFlow id="Flow_V12" sourceRef="Gw_V_Continue" targetRef="Task_V_Save" name="بله"/>
    <sequenceFlow id="Flow_V13" sourceRef="Gw_V_InsuranceValid" targetRef="Task_V_Save" name="بله"/>
    <sequenceFlow id="Flow_V14" sourceRef="Task_V_Save" targetRef="Task_V_Record"/>
    <sequenceFlow id="Flow_V15" sourceRef="Task_V_Record" targetRef="End_V"/>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_vehicle-registration">
    <bpmndi:BPMNPlane id="BPMNPlane_vehicle-registration" bpmnElement="vehicle-registration">
      <bpmndi:BPMNShape id="Lane_vehicle-registration_1_di" bpmnElement="Lane_vehicle-registration_1" isHorizontal="true">
        <dc:Bounds x="0" y="0" width="5880" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_vehicle-registration_2_di" bpmnElement="Lane_vehicle-registration_2" isHorizontal="true">
        <dc:Bounds x="0" y="220" width="5880" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_V_di" bpmnElement="Start_V">
