      <bpmndi:BPMNEdge id="Flow_V8_di" bpmnElement="Flow_V8">
        <di:waypoint x="1160" y="360.0"/>
        <di:waypoint x="1530" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_V9_di" bpmnElement="Flow_V9">
        <di:waypoint x="1580" y="360.0"/>
