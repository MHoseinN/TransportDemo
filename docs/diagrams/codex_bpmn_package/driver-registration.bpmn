<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_driver-registration" targetNamespace="https://example.com/transport-bpmn">
  <process id="driver-registration" name="فرآیند ثبت راننده" isExecutable="false">
    <laneSet id="LaneSet_driver-registration">
      <lane id="Lane_driver-registration_1" name="کاربر / ثبت‌کننده">
        <flowNodeRef>Start_D</flowNodeRef>
        <flowNodeRef>Task_D_Form</flowNodeRef>
        <flowNodeRef>Task_D_Branch</flowNodeRef>
        <flowNodeRef>Task_D_Identity</flowNodeRef>
        <flowNodeRef>Task_D_License</flowNodeRef>
        <flowNodeRef>Task_D_Insurance</flowNodeRef>
      </lane>
      <lane id="Lane_driver-registration_2" name="پشتیبانی / مسئول اداری">
        <flowNodeRef>Gw_D_Complete</flowNodeRef>
        <flowNodeRef>Task_D_Error</flowNodeRef>
        <flowNodeRef>Gw_D_InsuranceValid</flowNodeRef>
        <flowNodeRef>Task_D_Warn</flowNodeRef>
        <flowNodeRef>Gw_D_Continue</flowNodeRef>
        <flowNodeRef>Task_D_Save</flowNodeRef>
      </lane>
      <lane id="Lane_driver-registration_3" name="مالی / بیمه">
        <flowNodeRef>Task_D_Use</flowNodeRef>
        <flowNodeRef>End_D</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_D" name="شروع"/>
    <userTask id="Task_D_Form" name="ورود به فرم ثبت راننده"/>
    <task id="Task_D_Branch" name="انتخاب شعبه و نمایندگی"/>
    <task id="Task_D_Identity" name="ورود اطلاعات هویتی"/>
    <task id="Task_D_License" name="ورود موبایل و گواهینامه"/>
    <task id="Task_D_Insurance" name="ورود اطلاعات بیمه"/>
    <exclusiveGateway id="Gw_D_Complete" name="اطلاعات اصلی کامل است؟"/>
    <task id="Task_D_Error" name="نمایش خطا و اصلاح"/>
    <exclusiveGateway id="Gw_D_InsuranceValid" name="بیمه معتبر است؟"/>
    <task id="Task_D_Warn" name="نمایش هشدار بیمه"/>
    <exclusiveGateway id="Gw_D_Continue" name="ادامه ثبت مجاز است؟"/>
    <task id="Task_D_Save" name="ثبت راننده"/>
    <task id="Task_D_Use" name="استفاده از داده‌ها برای کنترل و محاسبات"/>
    <endEvent id="End_D" name="پایان"/>
    <sequenceFlow id="Flow_D1" sourceRef="Start_D" targetRef="Task_D_Form"/>
    <sequenceFlow id="Flow_D2" sourceRef="Task_D_Form" targetRef="Task_D_Branch"/>
    <sequenceFlow id="Flow_D3" sourceRef="Task_D_Branch" targetRef="Task_D_Identity"/>
    <sequenceFlow id="Flow_D4" sourceRef="Task_D_Identity" targetRef="Task_D_License"/>
    <sequenceFlow id="Flow_D5" sourceRef="Task_D_License" targetRef="Task_D_Insurance"/>
    <sequenceFlow id="Flow_D6" sourceRef="Task_D_Insurance" targetRef="Gw_D_Complete"/>
    <sequenceFlow id="Flow_D7" sourceRef="Gw_D_Complete" targetRef="Task_D_Error" name="خیر"/>
    <sequenceFlow id="Flow_D8" sourceRef="Task_D_Error" targetRef="Task_D_Branch"/>
    <sequenceFlow id="Flow_D9" sourceRef="Gw_D_Complete" targetRef="Gw_D_InsuranceValid" name="بله"/>
    <sequenceFlow id="Flow_D10" sourceRef="Gw_D_InsuranceValid" targetRef="Task_D_Warn" name="خیر"/>
    <sequenceFlow id="Flow_D11" sourceRef="Task_D_Warn" targetRef="Gw_D_Continue"/>
    <sequenceFlow id="Flow_D12" sourceRef="Gw_D_Continue" targetRef="Task_D_Branch" name="خیر"/>
    <sequenceFlow id="Flow_D13" sourceRef="Gw_D_Continue" targetRef="Task_D_Save" name="بله"/>
    <sequenceFlow id="Flow_D14" sourceRef="Gw_D_InsuranceValid" targetRef="Task_D_Save" name="بله"/>
    <sequenceFlow id="Flow_D15" sourceRef="Task_D_Save" targetRef="Task_D_Use"/>
    <sequenceFlow id="Flow_D16" sourceRef="Task_D_Use" targetRef="End_D"/>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_driver-registration">
    <bpmndi:BPMNPlane id="BPMNPlane_driver-registration" bpmnElement="driver-registration">
      <bpmndi:BPMNShape id="Lane_driver-registration_1_di" bpmnElement="Lane_driver-registration_1" isHorizontal="true">
        <dc:Bounds x="0" y="0" width="6300" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_driver-registration_2_di" bpmnElement="Lane_driver-registration_2" isHorizontal="true">
        <dc:Bounds x="0" y="220" width="6300" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_driver-registration_3_di" bpmnElement="Lane_driver-registration_3" isHorizontal="true">
        <dc:Bounds x="0" y="440" width="6300" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_D_di" bpmnElement="Start_D">
        <dc:Bounds x="60" y="122" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_D_Form_di" bpmnElement="Task_D_Form">
        <dc:Bounds x="270" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_D_Branch_di" bpmnElement="Task_D_Branch">
        <dc:Bounds x="480" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_D_Identity_di" bpmnElement="Task_D_Identity">
        <dc:Bounds x="690" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_D_License_di" bpmnElement="Task_D_License">
        <dc:Bounds x="900" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_D_Insurance_di" bpmnElement="Task_D_Insurance">
        <dc:Bounds x="1110" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_D_Complete_di" bpmnElement="Gw_D_Complete">
        <dc:Bounds x="1320" y="335" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_D_Error_di" bpmnElement="Task_D_Error">
        <dc:Bounds x="1530" y="320" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_D_InsuranceValid_di" bpmnElement="Gw_D_InsuranceValid">
        <dc:Bounds x="1740" y="335" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_D_Warn_di" bpmnElement="Task_D_Warn">
        <dc:Bounds x="1950" y="320" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_D_Continue_di" bpmnElement="Gw_D_Continue">
        <dc:Bounds x="2160" y="335" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_D_Save_di" bpmnElement="Task_D_Save">
        <dc:Bounds x="2370" y="320" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_D_Use_di" bpmnElement="Task_D_Use">
        <dc:Bounds x="2580" y="540" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_D_di" bpmnElement="End_D">
        <dc:Bounds x="2790" y="562" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_D1_di" bpmnElement="Flow_D1">
        <di:waypoint x="96" y="140.0"/>
        <di:waypoint x="270" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D2_di" bpmnElement="Flow_D2">
        <di:waypoint x="410" y="140.0"/>
        <di:waypoint x="480" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D3_di" bpmnElement="Flow_D3">
        <di:waypoint x="620" y="140.0"/>
        <di:waypoint x="690" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D4_di" bpmnElement="Flow_D4">
        <di:waypoint x="830" y="140.0"/>
        <di:waypoint x="900" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D5_di" bpmnElement="Flow_D5">
        <di:waypoint x="1040" y="140.0"/>
        <di:waypoint x="1110" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D6_di" bpmnElement="Flow_D6">
        <di:waypoint x="1250" y="140.0"/>
        <di:waypoint x="1290" y="140.0"/>
        <di:waypoint x="1290" y="360.0"/>
        <di:waypoint x="1320" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D7_di" bpmnElement="Flow_D7">
        <di:waypoint x="1370" y="360.0"/>
        <di:waypoint x="1530" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D8_di" bpmnElement="Flow_D8">
        <di:waypoint x="1670" y="360.0"/>
        <di:waypoint x="1690" y="360.0"/>
        <di:waypoint x="1690" y="60"/>
        <di:waypoint x="460" y="60"/>
        <di:waypoint x="460" y="140.0"/>
        <di:waypoint x="480" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D9_di" bpmnElement="Flow_D9">
        <di:waypoint x="1370" y="360.0"/>
        <di:waypoint x="1740" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D10_di" bpmnElement="Flow_D10">
        <di:waypoint x="1790" y="360.0"/>
        <di:waypoint x="1950" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D11_di" bpmnElement="Flow_D11">
        <di:waypoint x="2090" y="360.0"/>
        <di:waypoint x="2160" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D12_di" bpmnElement="Flow_D12">
        <di:waypoint x="2210" y="360.0"/>
        <di:waypoint x="2230" y="360.0"/>
        <di:waypoint x="2230" y="60"/>
        <di:waypoint x="460" y="60"/>
        <di:waypoint x="460" y="140.0"/>
        <di:waypoint x="480" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D13_di" bpmnElement="Flow_D13">
        <di:waypoint x="2210" y="360.0"/>
        <di:waypoint x="2370" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D14_di" bpmnElement="Flow_D14">
        <di:waypoint x="1790" y="360.0"/>
        <di:waypoint x="2370" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D15_di" bpmnElement="Flow_D15">
        <di:waypoint x="2510" y="360.0"/>
        <di:waypoint x="2550" y="360.0"/>
        <di:waypoint x="2550" y="580.0"/>
        <di:waypoint x="2580" y="580.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D16_di" bpmnElement="Flow_D16">
        <di:waypoint x="2720" y="580.0"/>
        <di:waypoint x="2790" y="580.0"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
