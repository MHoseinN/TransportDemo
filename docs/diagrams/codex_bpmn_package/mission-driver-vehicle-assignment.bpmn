<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_mission-driver-vehicle-assignment" targetNamespace="https://example.com/transport-bpmn">
  <process id="mission-driver-vehicle-assignment" name="فرآیند انتخاب راننده و انتصاب خودرو به مأموریت" isExecutable="false">
    <laneSet id="LaneSet_mission-driver-vehicle-assignment">
      <lane id="Lane_mission-driver-vehicle-assignment_1" name="کارشناس ترابری">
        <flowNodeRef>Start_AS</flowNodeRef>
        <flowNodeRef>Task_AS_Inbox</flowNodeRef>
        <flowNodeRef>Task_AS_Mission</flowNodeRef>
        <flowNodeRef>Task_AS_Drivers</flowNodeRef>
        <flowNodeRef>Task_AS_Vehicles</flowNodeRef>
        <flowNodeRef>Task_AS_SelectDriver</flowNodeRef>
        <flowNodeRef>Task_AS_SelectVehicle</flowNodeRef>
        <flowNodeRef>Task_AS_ConfirmReq</flowNodeRef>
        <flowNodeRef>Gw_AS_Confirm</flowNodeRef>
        <flowNodeRef>Task_AS_Save</flowNodeRef>
      </lane>
      <lane id="Lane_mission-driver-vehicle-assignment_2" name="کنترل اعتبار / پشتیبانی">
        <flowNodeRef>Gw_AS_DriverAvailable</flowNodeRef>
        <flowNodeRef>Gw_AS_VehicleValid</flowNodeRef>
      </lane>
      <lane id="Lane_mission-driver-vehicle-assignment_3" name="راننده">
        <flowNodeRef>Task_AS_NotifyDriver</flowNodeRef>
        <flowNodeRef>End_AS</flowNodeRef>
      </lane>
    </laneSet>
    <startEvent id="Start_AS" name="شروع"/>
    <userTask id="Task_AS_Inbox" name="ورود به کارتابل ترابری"/>
    <task id="Task_AS_Mission" name="انتخاب مأموریت تأییدشده"/>
    <task id="Task_AS_Drivers" name="نمایش رانندگان آماده سرویس"/>
    <task id="Task_AS_Vehicles" name="نمایش خودروهای آماده سرویس"/>
    <task id="Task_AS_SelectDriver" name="انتخاب راننده"/>
    <task id="Task_AS_SelectVehicle" name="انتخاب خودرو"/>
    <exclusiveGateway id="Gw_AS_DriverAvailable" name="راننده در دسترس است؟"/>
    <exclusiveGateway id="Gw_AS_VehicleValid" name="خودرو معتبر، سالم و بیمه‌دار است؟"/>
    <task id="Task_AS_ConfirmReq" name="درخواست تأیید انتصاب"/>
    <exclusiveGateway id="Gw_AS_Confirm" name="تأیید انتصاب؟"/>
    <task id="Task_AS_Save" name="ثبت انتصاب"/>
    <task id="Task_AS_NotifyDriver" name="دریافت مأموریت تخصیص‌یافته"/>
    <endEvent id="End_AS" name="پایان"/>
    <sequenceFlow id="Flow_AS1" sourceRef="Start_AS" targetRef="Task_AS_Inbox"/>
    <sequenceFlow id="Flow_AS2" sourceRef="Task_AS_Inbox" targetRef="Task_AS_Mission"/>
    <sequenceFlow id="Flow_AS3" sourceRef="Task_AS_Mission" targetRef="Task_AS_Drivers"/>
    <sequenceFlow id="Flow_AS4" sourceRef="Task_AS_Drivers" targetRef="Task_AS_Vehicles"/>
    <sequenceFlow id="Flow_AS5" sourceRef="Task_AS_Vehicles" targetRef="Task_AS_SelectDriver"/>
    <sequenceFlow id="Flow_AS6" sourceRef="Task_AS_SelectDriver" targetRef="Task_AS_SelectVehicle"/>
    <sequenceFlow id="Flow_AS7" sourceRef="Task_AS_SelectVehicle" targetRef="Gw_AS_DriverAvailable"/>
    <sequenceFlow id="Flow_AS8" sourceRef="Gw_AS_DriverAvailable" targetRef="Task_AS_Drivers" name="خیر"/>
    <sequenceFlow id="Flow_AS9" sourceRef="Gw_AS_DriverAvailable" targetRef="Gw_AS_VehicleValid" name="بله"/>
    <sequenceFlow id="Flow_AS10" sourceRef="Gw_AS_VehicleValid" targetRef="Task_AS_Vehicles" name="خیر"/>
    <sequenceFlow id="Flow_AS11" sourceRef="Gw_AS_VehicleValid" targetRef="Task_AS_ConfirmReq" name="بله"/>
    <sequenceFlow id="Flow_AS12" sourceRef="Task_AS_ConfirmReq" targetRef="Gw_AS_Confirm"/>
    <sequenceFlow id="Flow_AS13" sourceRef="Gw_AS_Confirm" targetRef="Task_AS_SelectDriver" name="خیر"/>
    <sequenceFlow id="Flow_AS14" sourceRef="Gw_AS_Confirm" targetRef="Task_AS_Save" name="بله"/>
    <sequenceFlow id="Flow_AS15" sourceRef="Task_AS_Save" targetRef="Task_AS_NotifyDriver"/>
    <sequenceFlow id="Flow_AS16" sourceRef="Task_AS_NotifyDriver" targetRef="End_AS"/>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_mission-driver-vehicle-assignment">
    <bpmndi:BPMNPlane id="BPMNPlane_mission-driver-vehicle-assignment" bpmnElement="mission-driver-vehicle-assignment">
      <bpmndi:BPMNShape id="Lane_mission-driver-vehicle-assignment_1_di" bpmnElement="Lane_mission-driver-vehicle-assignment_1" isHorizontal="true">
        <dc:Bounds x="0" y="0" width="6300" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_mission-driver-vehicle-assignment_2_di" bpmnElement="Lane_mission-driver-vehicle-assignment_2" isHorizontal="true">
        <dc:Bounds x="0" y="220" width="6300" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_mission-driver-vehicle-assignment_3_di" bpmnElement="Lane_mission-driver-vehicle-assignment_3" isHorizontal="true">
        <dc:Bounds x="0" y="440" width="6300" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_AS_di" bpmnElement="Start_AS">
        <dc:Bounds x="60" y="122" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AS_Inbox_di" bpmnElement="Task_AS_Inbox">
        <dc:Bounds x="270" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AS_Mission_di" bpmnElement="Task_AS_Mission">
        <dc:Bounds x="480" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AS_Drivers_di" bpmnElement="Task_AS_Drivers">
        <dc:Bounds x="690" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AS_Vehicles_di" bpmnElement="Task_AS_Vehicles">
        <dc:Bounds x="900" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AS_SelectDriver_di" bpmnElement="Task_AS_SelectDriver">
        <dc:Bounds x="1110" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AS_SelectVehicle_di" bpmnElement="Task_AS_SelectVehicle">
        <dc:Bounds x="1320" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_AS_DriverAvailable_di" bpmnElement="Gw_AS_DriverAvailable">
        <dc:Bounds x="1530" y="335" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_AS_VehicleValid_di" bpmnElement="Gw_AS_VehicleValid">
        <dc:Bounds x="1740" y="335" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AS_ConfirmReq_di" bpmnElement="Task_AS_ConfirmReq">
        <dc:Bounds x="1950" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gw_AS_Confirm_di" bpmnElement="Gw_AS_Confirm">
        <dc:Bounds x="2160" y="115" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AS_Save_di" bpmnElement="Task_AS_Save">
        <dc:Bounds x="2370" y="100" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AS_NotifyDriver_di" bpmnElement="Task_AS_NotifyDriver">
        <dc:Bounds x="2580" y="540" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_AS_di" bpmnElement="End_AS">
        <dc:Bounds x="2790" y="562" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_AS1_di" bpmnElement="Flow_AS1">
        <di:waypoint x="96" y="140.0"/>
        <di:waypoint x="270" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS2_di" bpmnElement="Flow_AS2">
        <di:waypoint x="410" y="140.0"/>
        <di:waypoint x="480" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS3_di" bpmnElement="Flow_AS3">
        <di:waypoint x="620" y="140.0"/>
        <di:waypoint x="690" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS4_di" bpmnElement="Flow_AS4">
        <di:waypoint x="830" y="140.0"/>
        <di:waypoint x="900" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS5_di" bpmnElement="Flow_AS5">
        <di:waypoint x="1040" y="140.0"/>
        <di:waypoint x="1110" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS6_di" bpmnElement="Flow_AS6">
        <di:waypoint x="1250" y="140.0"/>
        <di:waypoint x="1320" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS7_di" bpmnElement="Flow_AS7">
        <di:waypoint x="1460" y="140.0"/>
        <di:waypoint x="1500" y="140.0"/>
        <di:waypoint x="1500" y="360.0"/>
        <di:waypoint x="1530" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS8_di" bpmnElement="Flow_AS8">
        <di:waypoint x="1580" y="360.0"/>
        <di:waypoint x="1600" y="360.0"/>
        <di:waypoint x="1600" y="60"/>
        <di:waypoint x="670" y="60"/>
        <di:waypoint x="670" y="140.0"/>
        <di:waypoint x="690" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS9_di" bpmnElement="Flow_AS9">
        <di:waypoint x="1580" y="360.0"/>
        <di:waypoint x="1740" y="360.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS10_di" bpmnElement="Flow_AS10">
        <di:waypoint x="1790" y="360.0"/>
        <di:waypoint x="1810" y="360.0"/>
        <di:waypoint x="1810" y="60"/>
        <di:waypoint x="880" y="60"/>
        <di:waypoint x="880" y="140.0"/>
        <di:waypoint x="900" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS11_di" bpmnElement="Flow_AS11">
        <di:waypoint x="1790" y="360.0"/>
        <di:waypoint x="1830" y="360.0"/>
        <di:waypoint x="1830" y="140.0"/>
        <di:waypoint x="1950" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS12_di" bpmnElement="Flow_AS12">
        <di:waypoint x="2090" y="140.0"/>
        <di:waypoint x="2160" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS13_di" bpmnElement="Flow_AS13">
        <di:waypoint x="2210" y="140.0"/>
        <di:waypoint x="2230" y="140.0"/>
        <di:waypoint x="2230" y="60"/>
        <di:waypoint x="1090" y="60"/>
        <di:waypoint x="1090" y="140.0"/>
        <di:waypoint x="1110" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS14_di" bpmnElement="Flow_AS14">
        <di:waypoint x="2210" y="140.0"/>
        <di:waypoint x="2370" y="140.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS15_di" bpmnElement="Flow_AS15">
        <di:waypoint x="2510" y="140.0"/>
        <di:waypoint x="2550" y="140.0"/>
        <di:waypoint x="2550" y="580.0"/>
        <di:waypoint x="2580" y="580.0"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AS16_di" bpmnElement="Flow_AS16">
        <di:waypoint x="2720" y="580.0"/>
        <di:waypoint x="2790" y="580.0"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
